# ============================================
# Environment Configuration
# ============================================
# Copy this file to `.env` and fill the values.

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://sujliykbkpxdxitgbzwi.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# API Configuration
# ============================================
# Development: Use localhost backend
# Production: Use Render deployed backend URL
# Example production: https://api.vijayalakshmiboyarmatrimony.com

VITE_API_URL=http://localhost:3001
VITE_BACKUP_API_URL=http://localhost:3001

# ============================================
# Admin Authentication
# ============================================
VITE_ADMIN_API_KEY=your-secure-admin-api-key

# ============================================
# Deployment Mode
# ============================================
# Set to 'production' for live deployment
VITE_DEPLOYMENT_MODE=development
# Options: 'development' | 'production'

# ============================================
# Subdomain Configuration (for production)
# ============================================
# Client App: app.vijayalakshmiboyarmatrimony.com
# Admin App: admin.vijayalakshmiboyarmatrimony.com
VITE_CLIENT_DOMAIN=app.vijayalakshmiboyarmatrimony.com
VITE_ADMIN_DOMAIN=admin.vijayalakshmiboyarmatrimony.com
