# ============================================
# Frontend Environment Configuration
# ============================================
# Copy this file to `.env` and fill the values.
# 
# IMPORTANT: All frontend env vars must start with VITE_
# These are exposed to the browser - never use secrets!
# ============================================

# ============================================
# REQUIRED VARIABLES
# ============================================
# These are required for the app to function.
# The app will show a configuration error screen if missing.

# Supabase Project URL (found in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (found in Supabase Dashboard > Settings > API)
# This is the PUBLIC anon key, NOT the service role key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# API Configuration
# ============================================
# Backend API URL (Render deployment) - PRIMARY VARIABLE
VITE_API_BASE_URL=https://matrimony-backend-8hk0.onrender.com

# Legacy: VITE_API_URL (kept for backward compatibility)
# VITE_API_URL=https://matrimony-backend-8hk0.onrender.com

# Local development fallback (only used when running locally)
# VITE_BACKUP_API_URL=http://localhost:3001

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Admin Authentication Key (for admin features)
VITE_ADMIN_API_KEY=your-secure-admin-api-key

# Deployment Mode: 'development' or 'production'
VITE_DEPLOYMENT_MODE=development

# Subdomain Configuration (for production subdomain routing)
VITE_CLIENT_DOMAIN=app.vijayalakshmiboyarmatrimony.com
VITE_ADMIN_DOMAIN=admin.vijayalakshmiboyarmatrimony.com

# ============================================
# CLOUDFLARE PAGES DEPLOYMENT
# ============================================
# In Cloudflare Pages > Settings > Environment Variables, add:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_API_URL (set to your Render backend URL)
# - VITE_DEPLOYMENT_MODE=production
# ============================================
