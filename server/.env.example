# ============================================
# Supabase Configuration (Required)
# ============================================
SUPABASE_URL=https://sujliykbkpxdxitgbzwi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_BUCKETS=person-images,attachments,profile-assets,chat-files

# ============================================
# Google Drive Configuration
# ============================================
GOOGLE_DRIVE_FOLDER_ID=your-folder-id
GOOGLE_DRIVE_FOLDER_NAME=Vijayalakshmi_Matrimony_Backups
GOOGLE_DRIVE_CLIENT_ID=your-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# Server Configuration (Required for Render)
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
# Domains allowed for CORS (comma-separated)
CLIENT_DOMAIN=app.vijayalakshmiboyarmatrimony.com
ADMIN_DOMAIN=admin.vijayalakshmiboyarmatrimony.com
ALLOWED_ORIGINS=https://app.vijayalakshmiboyarmatrimony.com,https://admin.vijayalakshmiboyarmatrimony.com

# Cloudflare Pages URL (for preview deployments)
CLOUDFLARE_PAGES_URL=

# ============================================
# Backup Configuration
# ============================================
BACKUP_OUTPUT_DIR=./backups
TEMP_BACKUP_DIR=./temp/backup
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COUNT=7
BACKUP_RETRY_ATTEMPTS=3
BACKUP_RETRY_DELAY_MS=5000

# PostgreSQL Dump Path (optional)
PG_DUMP_PATH=

# ============================================
# Admin Authentication
# ============================================
ADMIN_API_KEY=your-secure-admin-api-key
ADMIN_EMAIL=admin@vijayalakshmiboyarmatrimony.com

# ============================================
# Security
# ============================================
# Generate a secure key: openssl rand -hex 32
API_SECRET_KEY=your-32-char-secret-key-here
