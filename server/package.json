{
  "name": "matrimony-backup-server",
  "version": "1.0.0",
  "description": "Backup server for Matrimony app - handles database and file backups to Google Drive",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "backup:manual": "tsx src/scripts/manual-backup.ts",
    "backup:cleanup": "tsx src/scripts/cleanup-old-backups.ts",
    "backup:retention-cleanup": "tsx src/scripts/cleanup-backups.ts",
    "scheduler": "tsx src/scripts/scheduler.ts",
    "restore:local": "node scripts/runRestore.js --file",
    "restore:drive": "tsx src/scripts/restore-backup.ts",
    "restore:verify": "tsx src/scripts/restore-verify.ts",
    "backup:create": "node scripts/runBackup.js",
    "backup:verify": "node scripts/runBackup.js --verify",
    "restore:db": "node scripts/runRestore.js --file",
    "restore:storage": "node scripts/runRestore.js --file",
    "restore:full": "node scripts/runRestore.js --file"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@supabase/supabase-js": "^2.76.1",
    "@types/pg": "^8.20.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "fs-extra": "^11.2.0",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "@types/unzipper": "^0.10.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
